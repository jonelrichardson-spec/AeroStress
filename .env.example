# ── Supabase (backend + optional frontend auth) ──
# From Supabase: Project Settings → API → Project URL
SUPABASE_URL=https://your-project.supabase.co
# Project Settings → API → anon public key (frontend / public)
SUPABASE_KEY=your-anon-key
# Project Settings → API → service_role key (backend only – keep secret)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Project Settings → API → JWT Secret (backend only)
SUPABASE_JWT_SECRET=your-jwt-secret

# ── Backend (optional) ──
# Webhook called when an inspection is submitted (optional)
INSPECTION_SUBMITTED_WEBHOOK_URL=https://webhook.site/your-uuid
# For production: comma-separated frontend origins (e.g. Vercel URL)
# CORS_ORIGINS=https://your-app.vercel.app

# ── Frontend (Next.js) ──
# Supabase (for loading turbines directly when not using FastAPI backend)
# Same as SUPABASE_URL and the anon/public key from Supabase → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Mapbox: https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.your-mapbox-public-token
# To connect frontend to FastAPI backend (local or deployed):
# Local: NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Vercel: NEXT_PUBLIC_API_BASE_URL=https://your-backend-url (no trailing slash)
# Omit to use Supabase for turbines instead.
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
